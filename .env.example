# ── Admin credentials for /admin (hidden route — not linked from UI) ─────────
# Generate via http://localhost:3000/admin/setup (runs entirely in the browser).
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# ── Lock storage ─────────────────────────────────────────────────────────────
# Picks Upstash if KV_REST_API_URL + KV_REST_API_TOKEN are set; otherwise
# uses the local filesystem (data/locks.json).
#
# Railway deployment:
#   Mount a Volume at /app/data so data/locks.json survives redeploys.
#   Volumes → New Volume → Mount path: /app/data → Attach to your service.
#   No env vars needed. RAILWAY_PROJECT_ID is auto-injected and silences the
#   "filesystem in production" warning.
#
# Vercel deployment:
#   Filesystem doesn't persist on Vercel. Connect Upstash Redis via
#   Storage → Marketplace → Upstash Redis, then `vercel env pull .env.local`.
#   The two vars below get auto-injected on Vercel:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
